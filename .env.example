# AldoL AI Environment Variables
# Get your Gemini API Key from: https://aistudio.google.com/app/apikey
# Get your NVIDIA/OpenAI API Key from your provider's dashboard

# The Gemini API Key (Required for Frontend)
GEMINI_API_KEY=your_gemini_api_key_here

# The OpenAI/NVIDIA API Key (Optional for Backend Proxy)
# Default key: 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
OPENAI_API_KEY=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
OPENAI_API_BASE_URL=https://integrate.api.nvidia.com/v1
OPENAI_MODEL_NAME=openai/gpt-oss-120b

# Server Configuration
PORT=3000
NODE_ENV=development
